{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/keru-require-skill",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.local/bin/keru-check-output",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.local/bin/keru-judge-output",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/keru-gate-deliverable",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/keru-block-webfetch",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/keru-block-inline-interp",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/.local/bin/keru-safe-read",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
